{
  "name": "frescari-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm knip",
    "ci": "pnpm check",
    "dev": "turbo dev",
    "knip": "knip",
    "lint-staged": "lint-staged",
    "lint": "turbo lint",
    "test": "turbo test",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "typecheck": "turbo typecheck",
    "vercel:env:setup": "node scripts/setup-vercel-env.mjs",
    "worker:lot-freshness": "powershell -ExecutionPolicy Bypass -File scripts/start-lot-freshness-worker.ps1",
    "worker:lot-freshness:run-once": "powershell -ExecutionPolicy Bypass -File scripts/start-lot-freshness-worker.ps1 -RunOnce",
    "worker:notifications": "pnpm --filter @frescari/api run worker:notifications",
    "worker:notifications:run-once": "pnpm --filter @frescari/api run worker:notifications:run-once",
    "prepare": "husky"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.37",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@9.0.0"
}
