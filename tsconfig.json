{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@frescari/api": ["packages/api/src/index.ts"],
      "@frescari/db": ["packages/db/src/index.ts"],
      "@frescari/ui": ["packages/ui/src/index.ts"],
      "@frescari/validators": ["packages/validators/src/index.ts"],
      "better-auth/adapters/drizzle": [
        "node_modules/better-auth/dist/adapters/drizzle/index.js"
      ],
      "better-auth/next-js": ["node_modules/better-auth/dist/next-js/index.js"]
    }
  },
  "include": [
    "apps/web/next-env.d.ts",
    "apps/web/.next/types/**/*.ts",
    "apps/web/.next/dev/types/**/*.ts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "packages/api/src/**/*.ts",
    "packages/db/**/*.ts",
    "packages/ui/src/**/*.ts",
    "packages/ui/src/**/*.tsx",
    "packages/validators/src/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
