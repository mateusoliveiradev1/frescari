{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreBinaries": ["powershell", "stripe"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "packages/validators/src/index.ts": ["duplicates"]
  },
  "workspaces": {
    ".": {
      "entry": ["package.json", ".husky/pre-commit", "scripts/**/*.ps1"],
      "project": [
        "package.json",
        "pnpm-workspace.yaml",
        "turbo.json",
        "*.mjs",
        ".husky/*",
        "scripts/**/*.ps1"
      ]
    },
    "apps/web": {
      "entry": ["e2e/**/*.spec.ts", "src/**/*.test.ts", "src/**/*.test.tsx"],
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts", "*.config.{ts,mjs,cjs}"]
    },
    "packages/api": {
      "ignoreDependencies": ["ioredis"]
    },
    "packages/db": {
      "entry": [
        "src/add-*.ts",
        "src/create-tables.ts",
        "src/enable-postgis.ts",
        "src/raw_migration.ts",
        "src/seed-master.ts"
      ],
      "ignoreDependencies": ["bufferutil", "ws"]
    }
  }
}
