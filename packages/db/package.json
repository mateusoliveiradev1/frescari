{
  "name": "@frescari/db",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "db:seed": "tsx src/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:inspect-target": "tsx src/inspect-neon-target.ts",
    "launch:bootstrap": "tsx src/launch-bootstrap-cli.ts",
    "db:recovery-rehearsal": "tsx src/recovery-rehearsal.ts",
    "db:migrate": "tsx migrate.ts",
    "db:push": "drizzle-kit push",
    "db:apply-rls": "tsx src/apply-rls.ts",
    "db:deploy": "drizzle-kit push --force && tsx src/apply-rls.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bufferutil": "^4.1.0",
    "drizzle-orm": "0.45.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "drizzle-kit": "0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
