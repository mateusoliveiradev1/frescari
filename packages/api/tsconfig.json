{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "declaration": true,
        "sourceMap": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@frescari/db": [
                "../db/src"
            ],
            "@frescari/validators": [
                "../validators/src"
            ],
            "better-auth/adapters/drizzle": [
                "./node_modules/better-auth/dist/adapters/drizzle/index.js"
            ]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
