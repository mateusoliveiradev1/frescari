{
    "name": "@frescari/api",
    "version": "1.0.0",
    "private": true,
    "main": "src/index.ts",
    "scripts": {
        "test": "tsx --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
        "test:worker": "tsx --test src/workers/*.test.ts",
        "stripe:connect:audit-legacy": "tsx src/workers/stripe-connect-legacy-audit-cli.ts",
        "stripe:connect:backfill": "tsx src/workers/stripe-connect-backfill-cli.ts",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "worker:lot-freshness": "tsx src/workers/lot-freshness-cli.ts",
        "worker:lot-freshness:run-once": "tsx src/workers/lot-freshness-cli.ts --run-once",
        "worker:notifications": "tsx src/workers/notification-worker-cli.ts",
        "worker:notifications:run-once": "tsx src/workers/notification-worker-cli.ts --run-once"
    },
    "dependencies": {
        "@frescari/db": "workspace:*",
        "@frescari/validators": "workspace:*",
        "@trpc/server": "^11.16.0",
        "bullmq": "^5.72.0",
        "drizzle-orm": "0.45.2",
        "ioredis": "^5.10.1",
        "next": "16.2.2",
        "stripe": "17.7.0",
        "superjson": "^2.2.6",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "tsx": "^4.21.0",
        "typescript": "^5.4.5"
    }
}
